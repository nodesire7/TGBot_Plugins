{
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["whitelist", "blacklist"],
      "default": "blacklist",
      "title": "Filter Mode",
      "description": "Whitelist: block all except allowed; Blacklist: allow all except blocked"
    },
    "allowed_domains": {
      "type": "array",
      "items": {"type": "string"},
      "default": [],
      "title": "Allowed Domains",
      "description": "Domains allowed in whitelist mode"
    },
    "blocked_domains": {
      "type": "array",
      "items": {"type": "string"},
      "default": [],
      "title": "Blocked Domains",
      "description": "Domains blocked in blacklist mode"
    },
    "delete_message": {
      "type": "boolean",
      "default": true,
      "title": "Delete Message"
    },
    "warn_user": {
      "type": "boolean",
      "default": true,
      "title": "Warn User"
    },
    "warning_message": {
      "type": "string",
      "default": "Links are not allowed in this group.",
      "title": "Warning Message"
    },
    "exempt_admins": {
      "type": "boolean",
      "default": true,
      "title": "Exempt Admins"
    }
  }
}
